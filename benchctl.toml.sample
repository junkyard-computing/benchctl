# benchctl configuration sample.
# Precedence: defaults < this file < env (BENCHCTL_<SECTION>_<KEY>) < CLI flags.
# Copy to benchctl.toml and pass with --config, or rely on env/flag overrides.

[ssh]
# The booted "home base": stock image, SSH-reachable over the USB dongle.
host = "felix.bench.lan"
user = "root"
key = "/home/bench/.ssh/felix_ed25519"   # optional; omit to use the agent
port = 22
# Privileged on-device commands (pixel-ota, pixel-bootctl, reboot) need root.
# When true (default) they're wrapped in `sudo -n` — required for the documented
# `kalm` login (passwordless sudo). Set false only if `user` is root.
sudo = true
# Transport bounds so a half-up device can't hang the recover loop forever:
connect_timeout = 10.0    # ssh/scp -o ConnectTimeout (seconds)
command_timeout = 120.0   # max wall time per ssh command / scp push

[slots]
home_base = "a"        # the recovery anchor; the experiment uses the other slot
# How recover() returns to the home base:
#   "retry-exhaustion" — reboot the experiment until the bootloader rolls back (felix mainline; no power)
#   "power"            — passive rollback wait + one power-cycle backstop (needs a power backend)
#   "fastboot"         — operator UART<->fastboot cable swap (not autonomous)
rollback_via = "retry-exhaustion"
rollback_reboots = 7   # reboots to burn before the slot's retry budget is exhausted

[experiment]
# How benchctl talks to the experiment slot. felix mainline has no network -> "uart".
transport = "uart"     # "uart" | "ssh"
# If the uartfs agent isn't answering, `uartfs bootstrap` it and re-ping before
# refusing (a booted experiment still needs the agent launched).
auto_bootstrap = true

[flash]
# "uartfs"    — in-place delta-flash over UART from the running experiment slot (felix default)
# "pixel-ota" — flash the inactive slot from the home base (A/B dance)
# "fastboot"  — interactive cable-swap path
backend = "uartfs"

[uart]
# Local companion binaries to uartd (it owns the serial port). Invoked per turn.
# A string is shell-split; a list is used as-is.
command = ["uart", "--socket", "/run/uartd.sock"]
uartfs_command = ["uartfs", "--socket", "/run/uartd.sock"]

[battery]
# felix is battery-only and can't charge while rigged for UART. benchctl counts
# reboots and refuses an iteration that can't safely complete.
floor_voltage = 3.5    # single-cell Li-ion floor (read via fastboot when available)
reboot_budget = 0      # max reboots per iteration; 0 == unenforced

[power]
# OPTIONAL. felix has no power relay -> set backend = "none" (or omit the section).
# backend: "none" | "tasmota" | "shelly" | "uhubctl"
backend = "none"
address = "http://10.0.0.42"

[power.options]
cycle_delay = 5         # seconds the relay stays off during a cycle
timeout = 5.0           # HTTP request timeout (tasmota/shelly) — keep finite
# channel = 0           # shelly only: relay index
# location = "1-2"      # uhubctl only: hub location (uhubctl -l)
# port = 3              # uhubctl only: hub port number

[timeouts]
boot = 120.0            # UART capture window for the experiment boot
rollback_wait = 180.0   # how long to wait for auto-rollback before the power backstop
power_cycle_wait = 180.0
ssh_probe = 5.0
poll_interval = 5.0     # between home-base reachability probes during recovery
